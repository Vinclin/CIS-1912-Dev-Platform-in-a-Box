# Environment template for the Jarvis chat service.
# Copy to backend/services/chat/docker.env within the Jarvis repo.

DATABASE_URL=postgresql://jarvis:password@db:5432/jarvis
FRONTEND_URL=http://localhost:3000
AUTH_SERVICE_URL=http://auth-service:8000
REDIS_URL=redis://redis:6379/0
GEMINI_MODEL=gemini-2.0-flash
APP_NAME=Jarvis Chat Service
DEBUG=True
TASK_QUEUE_TIMEOUT=300
AGENTIC_PLANNING_TIMEOUT=60
TASK_DETECTION_CONFIDENCE_THRESHOLD=0.7
