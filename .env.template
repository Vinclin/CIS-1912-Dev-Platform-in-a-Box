# Default configuration for the Developer Platform in a Box project.
# Copy to `.env` and adjust values for your local environment.

# Absolute or relative path to the project you want to automate.
TARGET_ROOT=../path/to/your/project

# Docker Compose settings
COMPOSE_FILE=compose.yaml
COMPOSE_PROJECT_NAME=devplatform
COMPOSE_UP_FLAGS=--build --detach

# Service directory hints (relative to TARGET_ROOT)
PYTHON_SERVICE_DIR=backend
FRONTEND_DIR=frontend
MIGRATOR_DIR=backend/migrator
